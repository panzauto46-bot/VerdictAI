# IPFS upload
VITE_PINATA_JWT=
VITE_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Explorer links
VITE_TX_EXPLORER_URL=

# GenLayer network
VITE_GENLAYER_CHAIN=testnetBradbury
VITE_GENLAYER_ENDPOINT=
VITE_GENLAYER_CONTRACT_ADDRESS=

# Optional remote verdict source
# Expected response JSON:
# {
#   "winner": "A" | "B" | "split",
#   "confidence": number,
#   "reasoning": string,
#   "awardPercentage": number,
#   "validators": number,
#   "consensusReached": boolean,
#   "timestamp": string
# }
VITE_GENLAYER_VERDICT_API_URL=
VITE_GENLAYER_VERDICT_API_KEY=

# Legacy ethers-style contract adapter fallback
# Only fill these if you also want the fallback ABI-based path.
# GenLayerJS only needs the GenLayer contract address above.
# Enable this only after your deployed contract exposes the standard methods:
# submitDispute
# respondToDispute
# requestAIVerdict
# withdrawFunds
# appealVerdict
VITE_VERDICTAI_CONTRACT_ADDRESS=
VITE_VERDICTAI_CONTRACT_ABI_JSON=[]
VITE_VERDICTAI_ENABLE_CONTRACT_WRITES=false
